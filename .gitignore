.claude/settings.local.json
.mcp.json

# Symlinks in references/ (created by git-sync) — ignore everything
# in references/ except tracked markdown docs and .gitkeep.
references/*
!references/*.md
!references/.gitkeep

# Same pattern for mcp_issues/ — symlinks to sibling mcp-* repos are
# per-machine, but shared .md notes should be tracked.
mcp_issues/*
!mcp_issues/*.md
!mcp_issues/.gitkeep
